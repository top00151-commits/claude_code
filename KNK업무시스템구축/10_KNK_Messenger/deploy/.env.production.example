# ============================================================
# KNK Messenger - 운영 환경변수 템플릿
# 실제 운영시 .env.production 으로 복사 후 SECRET 채우기
# 권한: chmod 600 .env.production (시스템 사용자만 읽기)
# ============================================================

# 운영 모드 켜기 (보안헤더·HTTPS 강제·CORS 제한 활성)
KNK_MSG_ENV=production

# 내부 포트 (nginx → 127.0.0.1:5050)
KNK_MSG_PORT=5050

# 세션 SECRET — 32자 이상 랜덤 hex. 절대 공개 X.
# 생성: python3 -c "import secrets; print(secrets.token_hex(32))"
KNK_MSG_SECRET=__CHANGE_ME_TO_64_HEX_CHARS__

# 메시지 보존 개월 수 (이후 자동 삭제, keep_forever 토글 방은 제외)
KNK_MSG_RETENTION_MONTHS=12

# Socket.IO async_mode: production = eventlet (gunicorn worker)
KNK_MSG_ASYNC=eventlet

# CORS allowed origins (콤마 구분, 또는 * 로 모두 허용)
KNK_MSG_CORS=https://msg.knknara.co.kr

# VAPID 푸시 알림 contact (Let's Encrypt와 동일하게 운영자 이메일)
KNK_MSG_CONTACT=mailto:admin@knknara.co.kr

# 신뢰할 프록시 수 (nginx 1대 = 1)
KNK_MSG_PROXIES=1

# (선택) S3 백업 대상. aws-cli 설치 + IAM 키 별도 ~/.aws/credentials
# KNK_BACKUP_S3=s3://knk-messenger-backup/
