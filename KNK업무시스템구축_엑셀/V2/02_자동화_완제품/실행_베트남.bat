@echo off
chcp 65001 >nul
setlocal
cd /d "%~dp0"

echo ================================================================
echo   KNK 자동화 완제품
echo   [베트남] 부서 진척 입력
echo   파일: KNK_자동화_완제품_베트남_입력_2026.xlsx
echo ================================================================
echo.
echo   Excel 파일이 열려있으면 모두 닫고 엔터를 누르세요.
pause

echo.
echo [1/2] sync.py 실행 중...
echo ----------------------------------------------------------------
python -X utf8 scripts\sync.py
if errorlevel 1 goto :ERROR

echo.
echo [2/2] apply_standard.py 실행 중 (스펙 20항 정규화)...
echo ----------------------------------------------------------------
python -X utf8 scripts\apply_standard.py
if errorlevel 1 goto :ERROR

echo.
echo ================================================================
echo   완료! 이 창은 5초 후 자동으로 닫힙니다.
echo ================================================================
timeout /t 5 >nul
exit /b 0

:ERROR
echo.
echo ================================================================
echo   [오류] 위 메시지를 확인한 뒤 엔터를 누르면 창이 닫힙니다.
echo ================================================================
pause
exit /b 1
